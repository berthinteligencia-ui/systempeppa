generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Company {
  id                 String            @id @default(cuid())
  name               String
  cnpj               String?           @unique
  logo               String?
  active             Boolean           @default(true)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  address            String?
  city               String?
  email              String?
  state              String?
  whatsapp           String?
  whatsappWebhookUrl String?
  webhookToken       String?
  backups            Backup[]
  comprovantes       Comprovante[]
  conversations      Conversation[]
  departments        Department[]
  employees          Employee[]
  invoices           Invoice[]
  notasFiscais       NotaFiscal[]
  payrollAnalyses    PayrollAnalysis[]
  settings           Settings?
  subscription       Subscription?
  users              User[]
}

model Plan {
  id               String         @id @default(cuid())
  name             String
  description      String?
  basePrice        Decimal        @db.Decimal(10, 2)
  pricePerEmployee Decimal        @db.Decimal(10, 2)
  active           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  billingType      String         @default("PER_EMPLOYEE")
  subscriptions    Subscription[]
}

model Subscription {
  id                     String   @id @default(cuid())
  companyId              String   @unique
  planId                 String
  customBasePrice        Decimal? @db.Decimal(10, 2)
  customPricePerEmployee Decimal? @db.Decimal(10, 2)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan                   Plan     @relation(fields: [planId], references: [id])
}

model Invoice {
  id                   String   @id @default(cuid())
  companyId            String
  amount               Decimal  @db.Decimal(10, 2)
  employeeCount        Int
  basePriceUsed        Decimal  @db.Decimal(10, 2)
  pricePerEmployeeUsed Decimal  @db.Decimal(10, 2)
  month                Int
  year                 Int
  status               String   @default("PENDING")
  dueDate              DateTime
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, month, year])
}

model Settings {
  id                    String   @id @default(cuid())
  companyId             String   @unique
  whatsappNotifications Boolean  @default(false)
  autoBackup            Boolean  @default(false)
  payrollReminderDays   Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  lastResetMonth        Int?
  lastResetYear         Int?
  company               Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(cuid())
  name               String
  email              String    @unique
  password           String
  role               Role      @default(RH)
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  companyId          String
  mustChangePassword Boolean   @default(false)
  accounts           Account[]
  sessions           Session[]
  company            Company   @relation(fields: [companyId], references: [id])
}

model Department {
  id              String            @id @default(cuid())
  name            String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  companyId       String
  cnpj            String?
  active          Boolean           @default(true)
  company         Company           @relation(fields: [companyId], references: [id])
  employees       Employee[]
  payrollAnalyses PayrollAnalysis[]
}

model Employee {
  id            String         @id @default(cuid())
  name          String
  cpf           String?        @unique
  email         String?
  phone         String?
  position      String
  salary        Decimal        @db.Decimal(10, 2)
  hireDate      DateTime
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  companyId     String
  departmentId  String?
  pagamento     String         @default("pendente")
  bankAccount   String?
  bankAgency    String?
  bankName      String?
  pixKey        String?
  comprovantes  Comprovante[]
  conversations Conversation[]
  company       Company        @relation(fields: [companyId], references: [id])
  department    Department?    @relation(fields: [departmentId], references: [id])
}

model Bank {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PayrollAnalysis {
  id           String        @id @default(cuid())
  month        Int
  year         Int
  departmentId String?
  companyId    String
  data         Json
  total        Decimal       @db.Decimal(10, 2)
  status       String        @default("OPEN")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  comprovantes Comprovante[]
  company      Company       @relation(fields: [companyId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])

  @@unique([month, year, departmentId, companyId], name: "month_year_unit_company")
}

model Comprovante {
  id           String           @id @default(cuid())
  fileName     String
  employeeName String
  cpf          String
  situacao     String
  amount       Decimal?         @db.Decimal(10, 2)
  extractedAt  DateTime         @default(now())
  companyId    String
  employeeId   String?
  fechamentoId String?
  fileUrl      String?
  originCnpj   String?
  generatedAt  String?
  company      Company          @relation(fields: [companyId], references: [id])
  employee     Employee?        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  fechamento   PayrollAnalysis? @relation(fields: [fechamentoId], references: [id])
}

model Conversation {
  id         String    @id @default(cuid())
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  companyId  String
  employeeId String
  company    Company   @relation(fields: [companyId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([companyId, employeeId])
}

model Message {
  id             String       @id @default(cuid())
  content        String
  senderId       String
  senderType     SenderType
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversationId String
  webhook        String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Backup {
  id        String   @id @default(cuid())
  fileName  String
  fileSize  Int
  status    String   @default("SUCCESS")
  createdAt DateTime @default(now())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model NotaFiscal {
  id          String   @id @default(cuid())
  numero      String
  emitente    String
  valor       Decimal  @db.Decimal(10, 2)
  dataEmissao DateTime
  descricao   String?
  status      NfStatus @default(PENDENTE)
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Leads {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome      String?
  celular   String?
  createdAt DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  messages  MensagensZap[]

  @@map("leads")
}

model MensagensZap {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId            String?   @map("lead_id") @db.Uuid
  conteudo          String?
  tipo              String?
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  numeroFuncionario String?   @map("numero_funcionario")
  funcionario       String?   @default("false")
  lead              Leads?    @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("mensagens_zap")
}

model ActivityLogs {
  id        BigInt    @id @default(autoincrement())
  userId    String?   @map("user_id")
  userName  String?   @map("user_name")
  userEmail String?   @map("user_email")
  companyId String?   @map("company_id")
  action    String?
  target    String?
  details   Json?
  ipAddress String?   @map("ip_address")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("activity_logs")
}

enum Role {
  ADMIN
  RH
  GESTOR
  FUNCIONARIO
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum SenderType {
  COMPANY
  EMPLOYEE
}

enum NfStatus {
  PENDENTE
  ANALISADA
  APROVADA
  REJEITADA
}
